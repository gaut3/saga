+    // ── Saga: real-loudness tap ───────────────────────────────────────────────
+    // A RenderersFactory whose audio sink PREPENDS a TeeAudioProcessor to the
+    // default chain via DefaultAudioProcessorChain(tee) — which keeps the stock
+    // silence-skip + Sonic processors AFTER the tee. The order is load-bearing;
+    // do NOT reorder when re-applying this patch after a just_audio bump:
+    //   1) Prepend, don't replace — replacing the chain with [tee] alone would
+    //      drop Sonic and break playback speed/pitch. The tee must be ADDED to
+    //      the default chain, not substituted for it.
+    //   2) Tee runs BEFORE Sonic, so the RMS reflects the content's loudness,
+    //      not the playback tempo (1.5x wouldn't inflate the meter).
+    // The tee observes decoded PCM in-process — no RECORD_AUDIO — and emits a
+    // throttled RMS level on JustAudioPlugin's RMS EventChannel.
+    private androidx.media3.exoplayer.RenderersFactory createRmsRenderersFactory() {
+        return new androidx.media3.exoplayer.DefaultRenderersFactory(context) {
+            @Override
+            protected androidx.media3.exoplayer.audio.AudioSink buildAudioSink(
+                    android.content.Context context,
+                    boolean enableFloatOutput,
+                    boolean enableAudioTrackPlaybackParams) {
+                androidx.media3.exoplayer.audio.TeeAudioProcessor tee =
+                    new androidx.media3.exoplayer.audio.TeeAudioProcessor(new RmsAudioBufferSink());
+                return new androidx.media3.exoplayer.audio.DefaultAudioSink.Builder(context)
+                    .setEnableFloatOutput(enableFloatOutput)
+                    .setEnableAudioTrackPlaybackParams(enableAudioTrackPlaybackParams)
+                    .setAudioProcessorChain(
+                        new androidx.media3.exoplayer.audio.DefaultAudioSink.DefaultAudioProcessorChain(tee))
+                    .build();
+            }
+        };
+    }
+
+    private class RmsAudioBufferSink
+            implements androidx.media3.exoplayer.audio.TeeAudioProcessor.AudioBufferSink {
+        private int encoding = androidx.media3.common.C.ENCODING_PCM_16BIT;
+        private long lastEmitNs = 0L;
+
+        @Override
+        public void flush(int sampleRateHz, int channelCount, int encoding) {
+            this.encoding = encoding;
+        }
+
+        @Override
+        public void handleBuffer(java.nio.ByteBuffer buffer) {
+            final int pos = buffer.position();
+            final int lim = buffer.limit();
+            double sumSq = 0.0;
+            int n = 0;
+            if (encoding == androidx.media3.common.C.ENCODING_PCM_16BIT) {
+                // Subsample (step 64 bytes = every 32nd sample); absolute gets so
+                // we never disturb the buffer position.
+                for (int i = pos; i + 1 < lim; i += 64) {
+                    int lo = buffer.get(i) & 0xFF;
+                    int hi = buffer.get(i + 1);
+                    short s = (short) ((hi << 8) | lo);
+                    double v = s / 32768.0;
+                    sumSq += v * v;
+                    n++;
+                }
+            } else if (encoding == androidx.media3.common.C.ENCODING_PCM_FLOAT) {
+                java.nio.ByteBuffer fb =
+                    buffer.duplicate().order(java.nio.ByteOrder.nativeOrder());
+                for (int i = pos; i + 4 <= lim; i += 128) {
+                    float f = fb.getFloat(i);
+                    sumSq += (double) f * f;
+                    n++;
+                }
+            } else {
+                return; // unsupported encoding → Dart uses synthetic envelope
+            }
+            if (n == 0) return;
+            final long now = System.nanoTime();
+            if (now - lastEmitNs < 20_000_000L) return; // ~50 Hz
+            lastEmitNs = now;
+            final double rms = Math.sqrt(sumSq / n);
+            mainHandler.post(new Runnable() {
+                @Override
+                public void run() {
+                    if (JustAudioPlugin.rmsEventChannel != null) {
+                        JustAudioPlugin.rmsEventChannel.success(Double.valueOf(rms));
+                    }
+                }
+            });
+        }
+    }
